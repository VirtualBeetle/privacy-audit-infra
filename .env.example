# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-use-a-long-random-string

# ─── AI Provider Key Encryption ────────────────────────────────────────────────
# AES-256-GCM key used to encrypt AI provider API keys stored in MongoDB.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=change-me-32-char-encryption-key

# ─── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── AI Risk Agent ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Tenant API Keys ───────────────────────────────────────────────────────────
# These are the plaintext API keys registered in the audit service.
# The audit-backend stores only the SHA-256 hash — keep these keys safe.
HEALTH_AUDIT_API_KEY=health-tenant-api-key
SOCIAL_AUDIT_API_KEY=social-tenant-api-key

# ─── MongoDB (AI Chat + AI Analysis) ──────────────────────────────────────────
# Docker Compose creates a mongo:7 container. You can also use MongoDB Atlas.
MONGODB_URI=mongodb://mongo:27017/privacy_audit_ai

# ─── Email (Nodemailer SMTP) ───────────────────────────────────────────────────
# Use Mailtrap for local dev (free, catches all emails without sending):
#   https://mailtrap.io → Email Testing → SMTP credentials
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-username
SMTP_PASS=your-mailtrap-password
FROM_EMAIL=privacy-audit@demo.local

# ─── Developer Tools ──────────────────────────────────────────────────────────
# Token to call /api/dev/* endpoints for demo triggers.
DEV_TOKEN=dev-secret-change-me
